{
    "name": "pushax/yii3-db-clickhouse",
    "type": "library",
    "description": "ClickHouse driver for Yii Database",
    "keywords": [
        "yii",
        "yii3",
        "clickhouse",
        "database",
        "sql",
        "dbal",
        "query-builder",
        "olap",
        "analytics"
    ],
    "license": "BSD-3-Clause",
    "support": {
        "issues": "https://github.com/pushax/yii3-db-clickhouse/issues",
        "source": "https://github.com/pushax/yii3-db-clickhouse"
    },
    "require": {
        "php": "8.1 - 8.5",
        "ext-ctype": "*",
        "ext-curl": "*",
        "psr/log": "^2.0|^3.0",
        "yiisoft/db": "^2.0",
        "yiisoft/db-migration": "^2.0"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "^1.8.3",
        "friendsofphp/php-cs-fixer": "^3.89.1",
        "maglnet/composer-require-checker": "^4.7.1",
        "phpunit/phpunit": "^10.5.45",
        "rector/rector": "^2.0.10",
        "spatie/phpunit-watcher": "^1.24",
        "vlucas/phpdotenv": "^5.6.1",
        "yiisoft/aliases": "^2.0",
        "yiisoft/log-target-file": "^2.0.1",
        "yiisoft/psr-dummy-provider": "^1.0",
        "yiisoft/test-support": "^3.0",
        "yiisoft/var-dumper": "^1.7"
    },
    "provide": {
        "yiisoft/db-implementation": "1.0.0"
    },
    "autoload": {
        "psr-4": {
            "Pushax\\Db\\ClickHouse\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pushax\\Db\\ClickHouse\\Tests\\": "tests",
            "Yiisoft\\Db\\Tests\\": "vendor/yiisoft/db/tests"
        },
        "files": ["tests/bootstrap.php"]
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": true,
            "target-directory": "tools",
            "forward-command": true
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true,
            "composer/package-versions-deprecated": true
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --testsuite unit --testdox",
        "test:integration": "vendor/bin/phpunit --testsuite integration --testdox",
        "test:all": "vendor/bin/phpunit --testdox",
        "test-watch": "vendor/bin/phpunit-watcher watch"
    }
}
